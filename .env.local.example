# Copy to .env.local and fill in (do not commit .env.local)
JIRA_BASE_URL=https://dzimalukyanau.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=

# Required for npm run scrum-master — repo where ai-teammate.yml lives
GITHUB_REPOSITORY=your-org/your-repo
GITHUB_TOKEN=

# Branch/tag that contains .github/workflows/* (must match where workflow files are pushed; 404 if wrong)
GITHUB_REF_NAME=main

# Optional — Scrum Master behavior
# REQUIRED_JIRA_STATUS=To Do
# POST_READ_STATUS=In Progress
# TICKET_CONTEXT_DEPTH=1
# SM_RULES_FILE=config/sm.json
