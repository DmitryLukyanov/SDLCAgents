{
  "name": "ai_teammate",
  "description": "AI Teammate pipeline: Jira → GitHub issue → Codex BA (separate Actions job) → start_developer_agent. The run_ba_inline step is config-only (skipIfLabel / addLabel); skipIfLabel is enforced in CI by the reusable workflow (Jira — check BA skip label). Do not rename run_ba_inline.",
  "params": {
    "runner": "pipeline",
    "ticketContextDepth": 1,
    "steps": [
      {
        "runner": "ensure_jira_fields_expected",
        "enabled": true,
        "onEmpty": {
          "action": "jira_transition",
          "status": "In Review",
          "comment": "Please provide a description before this ticket can be processed. The SDLC pipeline requires a description to generate a specification and implementation plan."
        }
      },
      {
        "runner": "print_jira_context_to_stdout",
        "enabled": true,
        "specKit": {}
      },
      {
        "runner": "create_github_issue",
        "enabled": true
      },
      {
        "runner": "run_ba_inline",
        "enabled": true,
        "comment": "Codex BA reads this block for skipIfLabel/addLabel only; BA runs in openai/codex-action, not here.",
        "skipIfLabel": "ba_analyzed",
        "addLabel": "ba_analyzed"
      },
      {
        "runner": "start_developer_agent",
        "enabled": true
      }
    ]
  }
}
