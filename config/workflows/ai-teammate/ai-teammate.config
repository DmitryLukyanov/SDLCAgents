{
  "name": "ai_teammate",
  "description": "AI Teammate pipeline: validate Jira → create GitHub issue → prepare BA artifacts → dispatch async BA (business-analyst.yml) → apply BA outcome → start developer agent. All routing via config; async boundary driven by async_call + contract.",
  "params": {
    "runner": "pipeline",
    "ticketContextDepth": 1,
    "skipIfLabel": "ba_analyzed",
    "addLabel": "ba_analyzed",
    "steps": [
      {
        "runner": "ensure_jira_fields_expected",
        "enabled": true,
        "onEmpty": {
          "action": "jira_transition",
          "status": "In Review",
          "comment": "Please provide a description before this ticket can be processed. The SDLC pipeline requires a description to generate a specification and implementation plan."
        }
      },
      {
        "runner": "create_github_issue",
        "enabled": true
      },
      {
        "id": "ba_async",
        "runner": "async_operation",
        "enabled": true,
        "async_call": {
          "workflowFile": "business-analyst.yml"
        },
        "contract": {
          "inputParams": {
            "prompt": {
              "kind": "artifact",
              "scope": "handoff_workspace",
              "relativePath": "invocation-prompt.md"
            },
            "jiraContext": {
              "kind": "artifact",
              "scope": "handoff_workspace",
              "relativePath": "invocation-jira-context.md"
            }
          },
          "outputParams": {
            "resultState": {
              "kind": "artifact",
              "scope": "handoff_workspace",
              "relativePath": "invocation-output.txt"
            }
          }
        }
      },
      {
        "runner": "apply_ba_outcome",
        "enabled": true
      },
      {
        "runner": "start_developer_agent",
        "enabled": false
      }
    ]
  }
}
