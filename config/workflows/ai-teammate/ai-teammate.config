{
  "name": "ai_teammate",
  "description": "AI Teammate pipeline: Jira → GitHub issue → optional async Codex BA (ba_codex_async + business-analyst.yml) → start_developer_agent. Codex never runs inside _reusable-ai-teammate. params.skipIfLabel gates the BA segment in CI.",
  "params": {
    "runner": "pipeline",
    "ticketContextDepth": 1,
    "skipIfLabel": "ba_analyzed",
    "addLabel": "ba_analyzed",
    "steps": [
      {
        "runner": "ensure_jira_fields_expected",
        "enabled": true,
        "onEmpty": {
          "action": "jira_transition",
          "status": "In Review",
          "comment": "Please provide a description before this ticket can be processed. The SDLC pipeline requires a description to generate a specification and implementation plan."
        }
      },
      {
        "runner": "print_jira_context_to_stdout",
        "enabled": true,
        "specKit": {}
      },
      {
        "runner": "create_github_issue",
        "enabled": true
      },
      {
        "id": "ba_codex_async",
        "runner": "ba_codex_async",
        "enabled": true,
        "comment": "Set enabled true + copy consumer-templates/business-analyst.yml to dispatch Codex in a separate workflow; ref defaults to the parent run branch.",
        "async_call": {
          "workflowFile": "business-analyst.yml"
        }
      },
      {
        "runner": "start_developer_agent",
        "enabled": false
      }
    ]
  }
}
