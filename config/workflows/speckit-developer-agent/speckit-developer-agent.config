{
  "name": "speckit_developer_agent",
  "description": "SpecKit Developer Agent: spec-kit workflow (specify → clarify → plan → tasks → implement → code_review). Runs Codex skills per step, manages feature branch + draft PR, commits artifacts, updates speckit-state.json.",
  "params": {
    "runner": "pipeline",
    "model": "o4-mini",
    "ticketContextDepth": 1,
    "branchNamePattern": "feature/{issueKey}-{timestamp}",
    "featureDirPattern": ".specify/features/{issueKey}",
    "draftPR": true,
    "defaultStepInputs": {
      "specify": "Analyze the ticket and create a detailed specification document that captures requirements, acceptance criteria, and key design considerations.",
      "clarify": "Review the specification and identify any ambiguities, missing information, or areas that need clarification. Document questions and assumptions.",
      "plan": "Create a high-level implementation plan that breaks down the work into logical phases and identifies key technical decisions.",
      "tasks": "Break down the implementation plan into concrete, actionable tasks with clear acceptance criteria.",
      "implement": "Implement the tasks following the plan and specification. Write clean, well-tested code that meets the requirements.",
      "code_review": "Review the implementation against tasks.md and spec.md. Write code-review-summary.md and .code-review-verdict (APPROVED or CHANGES_NEEDED) at the repo root; fix clear issues in code when safe."
    },
    "steps": [
      {
        "id": "validate_prerequisites",
        "runner": "validate_spec_kit_prerequisites",
        "enabled": true
      },
      {
        "id": "specify_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "specify",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      },
      {
        "id": "clarify_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "clarify",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      },
      {
        "id": "plan_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "plan",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      },
      {
        "id": "tasks_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "tasks",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      },
      {
        "id": "implement_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "implement",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      },
      {
        "id": "code_review_step",
        "runner": "spec_kit_step",
        "enabled": true,
        "stepName": "code_review",
        "async_call": {
          "workflowFile": "_reusable-codex-run.yml"
        }
      }
    ]
  }
}
