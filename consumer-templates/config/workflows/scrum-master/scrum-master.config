{
  "rules": [
    {
      "description": "To Do queue → Copilot Coding Agent via spec-kit pipeline",
      "jql": "project = {jiraProject} AND status = 'To Do' ORDER BY updated ASC",
      "configFile": "config/workflows/ai-teammate/ai-teammate.config",
      "workflowFile": "ai-teammate.yml",
      "workflowRef": "main",
      "limit": 10,
      "skipIfLabel": "sm_triggered",
      "addLabel": "sm_triggered"
    }
  ]
}
